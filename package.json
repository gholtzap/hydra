{
  "name": "hydra",
  "version": "0.3.3",
  "private": true,
  "description": "Hydra desktop shell built with Electron",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "build": "npm run build:main && npm run build:renderer && npm run build:assets",
    "build:icon": "./scripts/build-icon.sh build/icon-source.png",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:assets": "node scripts/build-assets.mjs",
    "start": "npm run build && electron .",
    "dev": "node scripts/dev.mjs",
    "dev:desktop": "npm run build && electron .",
    "dev:auth": "npm --prefix auth-server run dev:local",
    "pack": "npm run build && npm run build:icon && node scripts/run-electron-builder.mjs --dir",
    "pack:mac": "npm run build && node scripts/run-electron-builder.mjs --dir --mac --publish never",
    "smoke:packaged:mac": "node scripts/smoke-packaged-mac.mjs",
    "dist": "npm run build && npm run build:icon && node scripts/run-electron-builder.mjs",
    "dist:mac": "npm run build && node scripts/run-electron-builder.mjs --mac",
    "dist:win": "npm run build && node scripts/run-electron-builder.mjs --win",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "release:dry-run": "node scripts/release.mjs --dry-run"
  },
  "dependencies": {
    "@better-auth/electron": "^1.6.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "better-auth": "^1.6.5",
    "conf": "^15.1.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "tokscale": "^2.0.19"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  }
}
