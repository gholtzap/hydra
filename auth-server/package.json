{
  "name": "hydra-auth-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "generate": "npx @better-auth/cli generate --config src/auth.ts",
    "d1:migrate:local": "wrangler d1 migrations apply hydra-auth --local",
    "d1:migrate:remote": "wrangler d1 migrations apply hydra-auth --remote"
  },
  "dependencies": {
    "better-auth": "^1.6.5",
    "@better-auth/electron": "^1.6.5",
    "better-auth-cloudflare": "^0.3.0",
    "@better-auth/drizzle-adapter": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "better-sqlite3": "^12.0.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.8.0"
  }
}
