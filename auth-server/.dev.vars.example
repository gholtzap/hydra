# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-generated-secret
BETTER_AUTH_URL=http://localhost:8787
AUTH_ALLOWED_ORIGINS=app://-,http://localhost:3000,http://localhost:5173
# Native Electron deep-link auth trusts com.gmh.hydra:/ automatically.
# Set both values for any social provider you enable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
