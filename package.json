{
  "name": "hydra",
  "version": "0.1.13",
  "private": true,
  "description": "Hydra desktop shell built with Electron",
  "main": "dist-electron/main/main.js",
  "build": {
    "win": {
      "sign": false
    }
  },
  "scripts": {
    "build": "npm run build:main && npm run build:renderer && npm run build:assets",
    "build:icon": "./scripts/build-icon.sh build/icon-source.png",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:assets": "node scripts/build-assets.mjs",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "pack": "npm run build && npm run build:icon && node scripts/run-electron-builder.mjs --dir",
    "dist": "npm run build && npm run build:icon && node scripts/run-electron-builder.mjs",
    "dist:mac": "npm run build && npm run build:icon && node scripts/run-electron-builder.mjs --mac",
    "dist:win": "npm run build && node scripts/run-electron-builder.mjs --win",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "release:dry-run": "node scripts/release.mjs --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "tokscale": "^2.0.19"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  }
}
